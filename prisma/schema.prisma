generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ADMIN
  GESTOR
  PSICOLOGO
  ASSISTENTE_SOCIAL
  RECEPCAO
}

model Usuario {
  id           String         @id @default(cuid())
  nome         String
  email        String         @unique
  senha        String
  perfil       PerfilUsuario  @default(RECEPCAO)
  ativo        Boolean        @default(true)

  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt
}