generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ADMIN
  GESTOR
  PSICOLOGO
  ASSISTENTE_SOCIAL
  RECEPCAO
  CLIENTE
  COMITE_CLIENTE
}

enum StatusAgendamento {
  AGENDADO
  REALIZADO
  CANCELADO
  REAGENDADO
}

enum TipoAgendamento {
  APRESENTACAO_PLANO
  REUNIAO_ALINHAMENTO
  DEVOLUTIVA
  OUTRO
}

enum StatusPlanoAcao {
  RASCUNHO
  EM_ANDAMENTO
  CONCLUIDO
  ARQUIVADO
}

enum TipoPergunta {
  TEXTO
  TEXTO_LONGO
  NOTA
  MULTIPLA_ESCOLHA
  SIM_NAO
}

enum StatusPesquisaCliente {
  ABERTA
  FECHADA
  ARQUIVADA
}

enum TipoOrigemPlanoAcao {
  PESQUISA_CLIMA
  DENUNCIA
}

model Usuario {
  id     String @id @default(cuid())
  nome   String
  email  String @unique
  senha  String
  perfil PerfilUsuario @default(RECEPCAO)
  ativo  Boolean @default(true)

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  colaboradorCliente ColaboradorCliente?

  tratativasCriadas     TratativaDenuncia[] @relation("TratativaCriadaPor")
  tratativasAtualizadas TratativaDenuncia[] @relation("TratativaAtualizadaPor")

  @@index([clienteId])
  @@index([perfil])
}



model Cliente {
  id           String   @id @default(cuid())
  nome         String
  empresa      String?
  email        String?
  telefone     String?
  documento    String?
  observacoes  String?
  ativo        Boolean  @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuarios       Usuario[]
  pesquisas      PesquisaCliente[]
  colaboradores  ColaboradorCliente[]
  denuncias      Denuncia[]
}

model ModeloPesquisa {
  id           String   @id @default(cuid())
  titulo       String
  descricao    String?
  ativo        Boolean  @default(true)
  modeloPadrao Boolean  @default(false)

  perguntas Json @default("[]")

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  pesquisas    PesquisaCliente[]
}

model PesquisaCliente {
  id           String                @id @default(cuid())
  clienteId    String
  modeloId     String

  titulo       String
  descricao    String?
  token        String                @unique
  status       StatusPesquisaCliente @default(ABERTA)

  perguntas Json @default("[]")

  criadoEm     DateTime              @default(now())
  atualizadoEm DateTime              @updatedAt

  cliente      Cliente               @relation(fields: [clienteId], references: [id])
  modelo       ModeloPesquisa        @relation(fields: [modeloId], references: [id])
  respostas    RespostaPesquisa[]

  planosAcao   PlanoAcao[]

  convites ConvitePesquisa[]
}


model RespostaPesquisa {
  id           String   @id @default(cuid())
  pesquisaId   String

  nome         String?
  email        String?
  setor        String?
  cargo        String?

  respostas    Json

  criadoEm     DateTime @default(now())

  pesquisa     PesquisaCliente @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)

  convite      ConvitePesquisa? @relation(fields: [conviteId], references: [id], onDelete: SetNull)
  conviteId    String?  @unique
}

model PlanoAcao {
  id           String          @id @default(cuid())
  pesquisaId   String?

  titulo       String
  diagnostico  String?
  objetivo     String?
  conclusao    String?
  status       StatusPlanoAcao @default(RASCUNHO)

  acoes        Json            @default("[]")

  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt

  agendamentos Agendamento[]

  tipoOrigem TipoOrigemPlanoAcao @default(PESQUISA_CLIMA)

  denunciaId String?

  pesquisa PesquisaCliente? @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)

  denuncia Denuncia? @relation(fields: [denunciaId], references: [id], onDelete: Cascade)

  @@index([tipoOrigem])
  @@index([pesquisaId])
  @@index([denunciaId])
}

model Agendamento {
  id           String            @id @default(cuid())

  planoAcaoId  String?

  titulo       String
  descricao    String?
  dataHora     DateTime
  duracaoMin   Int               @default(60)
  local        String?
  linkReuniao  String?

  tipo         TipoAgendamento   @default(APRESENTACAO_PLANO)
  status       StatusAgendamento @default(AGENDADO)

  participantes Json             @default("[]")

  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt

  planoAcao    PlanoAcao?        @relation(fields: [planoAcaoId], references: [id], onDelete: SetNull)
}

model ConvitePesquisa {
  id           String   @id @default(cuid())
  pesquisaId   String

  token        String   @unique
  nome         String?
  email        String?
  setor        String?
  cargo        String?

  respondido   Boolean  @default(false)
  respondidoEm DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  pesquisa     PesquisaCliente   @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)
  resposta     RespostaPesquisa?
}




enum StatusDenuncia {
  RECEBIDA
  EM_ANALISE
  EM_TRATATIVA
  CONCLUIDA
  ARQUIVADA
}

enum GravidadeDenuncia {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

model ColaboradorCliente {
  id        String  @id @default(cuid())
  clienteId String
  usuarioId String? @unique

  nome     String
  email    String?
  telefone String?
  setor    String?
  cargo    String?
  ativo    Boolean @default(true)

  podeVerDenuncias    Boolean @default(true)
  podeTratarDenuncias Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  tratativasResponsavel TratativaDenuncia[] @relation("ResponsavelTratativa")

  @@index([clienteId])
  @@index([ativo])
}

model Denuncia {
  id        String @id @default(cuid())
  clienteId String

  protocolo String @unique
  titulo    String
  descricao String

  categoriaId String?
  categoria   CategoriaDenuncia? @relation(fields: [categoriaId], references: [id], onDelete: Restrict)

  localOcorrido String?
  dataOcorrido  DateTime?

  anonima             Boolean @default(true)
  nomeDenunciante     String?
  emailDenunciante    String?
  telefoneDenunciante String?

  status    StatusDenuncia    @default(RECEBIDA)
  gravidade GravidadeDenuncia @default(MEDIA)

  respostaPublica String?

  aceiteTermosEm      DateTime?
  versaoTermosAceitos String?
  ipAceiteHash        String?
  userAgentAceite     String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  cliente    Cliente              @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  anexos     AnexoDenuncia[]
  planosAcao PlanoAcao[]
  tratativas TratativaDenuncia[]
  historico  HistoricoDenuncia[]

  @@index([clienteId])
  @@index([categoriaId])
  @@index([status])
  @@index([gravidade])
  @@index([criadoEm])
}

model TratativaDenuncia {
  id         String @id @default(cuid())
  denunciaId String

  titulo    String
  descricao String

  responsavelId String?
  responsavel   ColaboradorCliente? @relation("ResponsavelTratativa", fields: [responsavelId], references: [id], onDelete: SetNull)

  criadoPorUsuarioId String?
  criadoPorUsuario   Usuario? @relation("TratativaCriadaPor", fields: [criadoPorUsuarioId], references: [id], onDelete: SetNull)

  atualizadoPorUsuarioId String?
  atualizadoPorUsuario   Usuario? @relation("TratativaAtualizadaPor", fields: [atualizadoPorUsuarioId], references: [id], onDelete: SetNull)

  criadoPorNome     String
  criadoPorPerfil   PerfilUsuario?
  atualizadoPorNome String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  denuncia Denuncia @relation(fields: [denunciaId], references: [id], onDelete: Cascade)

  @@index([denunciaId])
  @@index([responsavelId])
  @@index([criadoPorUsuarioId])
  @@index([atualizadoPorUsuarioId])
}

model AnexoDenuncia {
  id         String @id @default(cuid())
  denunciaId String

  nomeOriginal String
  chave        String @unique
  tipoMime     String
  tamanho      Int

  tipo         TipoAnexoDenuncia
  visibilidade VisibilidadeAnexoDenuncia @default(MUNDIAL_E_COMITE)

  criadoEm DateTime @default(now())

  denuncia Denuncia @relation(fields: [denunciaId], references: [id], onDelete: Cascade)

  @@index([denunciaId])
  @@index([tipo])
  @@index([visibilidade])
}

model HistoricoDenuncia {
  id         String @id @default(cuid())
  denunciaId String

  tipo      TipoEventoDenuncia
  titulo    String
  descricao String?

  statusAnterior StatusDenuncia?
  statusNovo     StatusDenuncia?

  origemAtor OrigemAtorDenuncia
  atorNome   String?
  atorId     String?

  visivelPublicamente Boolean @default(false)

  criadoEm DateTime @default(now())

  denuncia Denuncia @relation(fields: [denunciaId], references: [id], onDelete: Cascade)

  @@index([denunciaId, criadoEm])
  @@index([visivelPublicamente])
}







model RegraCriticidadeDenuncia {
  id        String            @id @default(cuid())
  termo     String
  categoria String?
  gravidade GravidadeDenuncia @default(ALTA)
  ativo     Boolean           @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model CategoriaDenuncia {
  id          String  @id @default(cuid())
  nome        String  @unique
  descricao   String?
  ativo       Boolean @default(true)
  ordem       Int     @default(0)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  denuncias Denuncia[]

  @@index([ativo, ordem])
}



enum TipoAnexoDenuncia {
  DOCUMENTO
  IMAGEM
  AUDIO
  VIDEO
  OUTRO
}

enum VisibilidadeAnexoDenuncia {
  SOMENTE_MUNDIAL
  MUNDIAL_E_COMITE
}

enum TipoEventoDenuncia {
  DENUNCIA_REGISTRADA
  STATUS_ALTERADO
  GRAVIDADE_ALTERADA
  TRATATIVA_CRIADA
  TRATATIVA_EDITADA
  RESPONSAVEL_ATRIBUIDO
  RESPOSTA_PUBLICA_ALTERADA
  ANEXO_ADICIONADO
}

enum OrigemAtorDenuncia {
  PUBLICO
  MUNDIAL
  CLIENTE
  COMITE_CLIENTE
  SISTEMA
}