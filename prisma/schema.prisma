generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ADMIN
  GESTOR
  PSICOLOGO
  ASSISTENTE_SOCIAL
  RECEPCAO
}

enum TipoPergunta {
  TEXTO
  TEXTO_LONGO
  NOTA
  MULTIPLA_ESCOLHA
  SIM_NAO
}

enum StatusPesquisaCliente {
  ABERTA
  FECHADA
  ARQUIVADA
}

model Usuario {
  id           String        @id @default(cuid())
  nome         String
  email        String        @unique
  senha        String
  perfil       PerfilUsuario @default(RECEPCAO)
  ativo        Boolean       @default(true)

  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt
}

model Cliente {
  id           String   @id @default(cuid())
  nome         String
  empresa      String?
  email        String?
  telefone     String?
  documento    String?
  observacoes  String?
  ativo        Boolean  @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  pesquisas    PesquisaCliente[]
}

model ModeloPesquisa {
  id           String   @id @default(cuid())
  titulo       String
  descricao    String?
  ativo        Boolean  @default(true)
  modeloPadrao Boolean  @default(false)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  perguntas    PerguntaPesquisa[]
  pesquisas    PesquisaCliente[]
}

model PerguntaPesquisa {
  id            String       @id @default(cuid())
  modeloId      String
  titulo        String
  descricao     String?
  tipo          TipoPergunta
  ordem         Int
  obrigatoria   Boolean      @default(true)

  // Para MULTIPLA_ESCOLHA, salvar como texto JSON:
  // ["Ruim", "Regular", "Bom", "Excelente"]
  opcoes        String?

  criadoEm      DateTime     @default(now())
  atualizadoEm  DateTime     @updatedAt

  modelo        ModeloPesquisa @relation(fields: [modeloId], references: [id], onDelete: Cascade)
  respostas     RespostaPergunta[]
}

model PesquisaCliente {
  id           String                @id @default(cuid())
  clienteId    String
  modeloId     String
  titulo       String
  descricao    String?
  token        String                @unique
  status       StatusPesquisaCliente @default(ABERTA)

  criadoEm     DateTime              @default(now())
  atualizadoEm DateTime              @updatedAt

  cliente      Cliente               @relation(fields: [clienteId], references: [id])
  modelo       ModeloPesquisa        @relation(fields: [modeloId], references: [id])
  respostas    RespostaPesquisa[]
}

model RespostaPesquisa {
  id           String   @id @default(cuid())
  pesquisaId   String
  nome         String?
  email        String?
  setor        String?
  cargo        String?

  criadoEm     DateTime @default(now())

  pesquisa     PesquisaCliente @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)
  respostas    RespostaPergunta[]
}

model RespostaPergunta {
  id           String   @id @default(cuid())
  respostaId   String
  perguntaId   String
  valor        String

  criadoEm     DateTime @default(now())

  resposta     RespostaPesquisa @relation(fields: [respostaId], references: [id], onDelete: Cascade)
  pergunta     PerguntaPesquisa @relation(fields: [perguntaId], references: [id])
}