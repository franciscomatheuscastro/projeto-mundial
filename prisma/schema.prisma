generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ADMIN
  GESTOR
  PSICOLOGO
  ASSISTENTE_SOCIAL
  RECEPCAO
}

enum TipoPergunta {
  TEXTO
  TEXTO_LONGO
  NOTA
  MULTIPLA_ESCOLHA
  SIM_NAO
}

enum StatusPesquisaCliente {
  ABERTA
  FECHADA
  ARQUIVADA
}

model Usuario {
  id           String        @id @default(cuid())
  nome         String
  email        String        @unique
  senha        String
  perfil       PerfilUsuario @default(RECEPCAO)
  ativo        Boolean       @default(true)

  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt
}

model Cliente {
  id           String   @id @default(cuid())
  nome         String
  empresa      String?
  email        String?
  telefone     String?
  documento    String?
  observacoes  String?
  ativo        Boolean  @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  pesquisas    PesquisaCliente[]
}

model ModeloPesquisa {
  id           String   @id @default(cuid())
  titulo       String
  descricao    String?
  ativo        Boolean  @default(true)
  modeloPadrao Boolean  @default(false)

  perguntas Json @default("[]")

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  pesquisas    PesquisaCliente[]
}

model PesquisaCliente {
  id           String                @id @default(cuid())
  clienteId    String
  modeloId     String

  titulo       String
  descricao    String?
  token        String                @unique
  status       StatusPesquisaCliente @default(ABERTA)

  perguntas Json @default("[]")

  criadoEm     DateTime              @default(now())
  atualizadoEm DateTime              @updatedAt

  cliente      Cliente               @relation(fields: [clienteId], references: [id])
  modelo       ModeloPesquisa        @relation(fields: [modeloId], references: [id])
  respostas    RespostaPesquisa[]
}


model RespostaPesquisa {
  id           String   @id @default(cuid())
  pesquisaId   String

  nome         String?
  email        String?
  setor        String?
  cargo        String?

  respostas    Json

  criadoEm     DateTime @default(now())

  pesquisa     PesquisaCliente @relation(fields: [pesquisaId], references: [id], onDelete: Cascade)
}